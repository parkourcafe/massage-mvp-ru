# ============================================================
# Massage Marketplace MVP — environment configuration
# Copy to .env.local and fill in. The app runs in a degraded
# in-memory demo mode when these are not set, so the build,
# tests and local exploration work without external services.
# ============================================================

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
# Data backend: "memory" (default — in-memory demo store, used by tests
# and when Supabase is not configured) or "supabase" (persist to the
# Supabase Postgres project; requires the URL + SERVICE_ROLE_KEY above).
DB_BACKEND=memory

# --- OpenAI (AI match / AI import) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- YooKassa (billing, Russia MVP) ---
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_WEBHOOK_SECRET=

# --- Auth ---
# HMAC secret for the session cookie. Set a long random value in prod.
AUTH_SECRET=

# --- App ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
PRO_PLAN_PRICE_RUB=490
ADMIN_EMAILS=admin@example.com
